# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Site Configuration
VITE_SITE_URL=https://foundandaligned.com

# CAPTCHA Configuration (Cloudflare Turnstile)
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Pivot Feature Flags
VITE_FA_PIVOT_ENABLED=true
VITE_FA_MARKETS_ENABLED=true

# Public config (safe to expose)
VITE_PRIMARY_MARKETS="NYC,Los Angeles,Chicago,San Francisco Bay Area,Washington DC"

# Environment
NODE_ENV=development

# INSTRUCTIONS:
# 1. Copy this file to .env.local for local development
# 2. Replace placeholder values with real credentials
# 3. For production, set these same VITE_* variables in your hosting provider
# 4. Set TURNSTILE_SECRET_KEY in Supabase function secrets (not as VITE_*)
