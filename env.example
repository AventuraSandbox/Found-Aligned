# Site Configuration
VITE_SITE_URL=https://foundandaligned.com

# CAPTCHA Configuration (Cloudflare Turnstile)
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Email Configuration (Web3Forms - free tier available)
# Get your access key from: https://web3forms.com
VITE_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here

# Pivot Feature Flags
VITE_FA_PIVOT_ENABLED=true
VITE_FA_MARKETS_ENABLED=true

# Public config (safe to expose)
VITE_PRIMARY_MARKETS="NYC,Los Angeles,Chicago,San Francisco Bay Area,Washington DC"

# Environment
NODE_ENV=development
